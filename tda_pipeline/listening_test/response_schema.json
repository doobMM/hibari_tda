{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.tda/listening-test/response-schema.json",
  "title": "Listening Test Response Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["study_id", "created_at", "responses"],
  "properties": {
    "study_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "locale": {
      "type": "string",
      "default": "ko-KR"
    },
    "responses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "participant_id",
          "listener_group",
          "consent",
          "session_device",
          "stimuli_ratings",
          "pairwise_choices"
        ],
        "properties": {
          "participant_id": {
            "type": "string",
            "pattern": "^[A-Za-z0-9_-]{3,40}$"
          },
          "listener_group": {
            "type": "string",
            "enum": ["expert", "general", "unknown"]
          },
          "consent": {
            "type": "boolean"
          },
          "session_device": {
            "type": "string",
            "enum": ["mobile", "desktop", "tablet", "unknown"]
          },
          "age_band": {
            "type": "string",
            "enum": ["under20", "20s", "30s", "40s", "50plus", "unknown"]
          },
          "stimuli_ratings": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "stimulus_code",
                "similarity",
                "naturalness",
                "preference",
                "play_count"
              ],
              "properties": {
                "stimulus_code": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L"]
                },
                "similarity": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                },
                "naturalness": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                },
                "preference": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                },
                "play_count": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 3
                },
                "comment": {
                  "type": "string",
                  "maxLength": 1200
                }
              }
            }
          },
          "pairwise_choices": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["pair_id", "left", "right", "preferred"],
              "properties": {
                "pair_id": {
                  "type": "string",
                  "enum": ["B_vs_C", "D_vs_E", "B_vs_G"]
                },
                "left": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L"]
                },
                "right": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L"]
                },
                "preferred": {
                  "type": "string",
                  "enum": ["A", "B", "C", "D", "E", "F", "G", "H", "I", "J", "K", "L"]
                },
                "confidence": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 5
                }
              }
            }
          },
          "global_comment": {
            "type": "string",
            "maxLength": 2000
          }
        }
      }
    }
  }
}
