__pycache__/
*.pyc
*.pyo
*.egg-info/
.eggs/
dist/
build/
*.log
.env

# ── Claude Code 설정 분할 ──
# 공유(tracked): settings.json, commands/, rules/, agents/, skills/
# 개인(ignored): settings.local.json, agent-memory/, launch.json, plans/, scheduled_tasks.lock
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/rules/
!.claude/agents/
!.claude/skills/

# ── 대용량 바이너리 (재생성 가능) ──
*.pkl
*.mid
*.midi
*.musicxml
*.xml
*.wav
*.mp3
*.pt
*.npy
output/
generated_output/
# 예외: tda_pipeline/output/hibari+/ 는 공개 감상용으로 git add -f 개별 커밋
# (*.ogg, *.mid, README.md, metadata.json 만 포함 — WAV/MusicXML은 용량상 제외)

# ── 빌드 캐시 ──
tda_pipeline/docs/_eq_cache/
tda_pipeline/cache/models/

# ── 폰트 미리보기 (선택 완료) ──
tda_pipeline/docs/font_preview_*.pdf

# ── 포트폴리오 파생본 (업로드 금지, 본 파일 환대_포트폴리오.md/pdf만 추적) ──
tda_pipeline/docs/academic_paper_portfolio (short2).pdf
tda_pipeline/docs/academic_paper_portfolio (short3).pdf
tda_pipeline/docs/academic_paper (short).pdf

# ── 피드백 txt 원본 (세션 간 작업 메모, 공개 저장소 제외) ──
tda_pipeline/docs/260*피드백*.txt
tda_pipeline/docs/260*논문*.txt

# ── 세션 간 프롬프트 md (내부 작업 문서, 공개 저장소 제외) ──
tda_pipeline/prompts/
tda_pipeline/docs/*prompt*.md
tda_pipeline/docs/*prompt*.txt

# ── LaTeX 중간 산출물 ──
*.aux
*.out
